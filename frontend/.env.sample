# Backend Connection
VITE_BACKEND_BASE_URL="localhost:3000" # Backend URL without protocol
VITE_BACKEND_HOST="127.0.0.1:3000" # Backend host with port
VITE_USE_TLS="false" # true -> https/wss, false -> http/ws
VITE_INSECURE_SKIP_VERIFY="false"

# Frontend Runtime
VITE_FRONTEND_PORT="3001"
VITE_MOCK_API="false"
VITE_MOCK_SAAS="false"

# Default Product Preferences (New)
VITE_DEFAULT_LANGUAGE="zh-CN"
VITE_DEFAULT_LLM_MODEL="openai/gpt-4.1"
VITE_DEFAULT_LLM_BASE_URL="http://127.0.0.1:11434/v1"
VITE_DEFAULT_GIT_USER_NAME="openagent-bot"
VITE_DEFAULT_GIT_USER_EMAIL="dev@openagent.local"

# Optional Integrations
# VITE_GITHUB_TOKEN=""
# VITE_OLLAMA_BASE_URL="http://127.0.0.1:11434"
